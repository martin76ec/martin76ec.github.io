{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "baseUrl": "./",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@components": ["src/components/*"],
      "@hooks": ["src/hooks/*"],
      "@layouts": ["src/layouts/*"],
      "@pages": ["src/pages/*"],
      "@assets": ["src/assets/*"],
    }
  },
  "exclude": ["node_modules", "build"],
  "include": ["**/*.astro", "**/*.ts", "**/*.tsx"]
}