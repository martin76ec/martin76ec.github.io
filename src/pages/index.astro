---
import "@fontsource/anton";
import "@fontsource/work-sans";
import Layout from "../layouts/index.astro";
import LottieAnimation from "astro-integration-lottie/Lottie.astro";
import { Timeline, Projects } from "../components";

const milestones = [
  {
    year: 2017,
    description:
      "Joined UPS.NET academic community quito, a microsoft community for developers where I obtained cloud and mobile development knowledge and improved my communication skills sharing micrsosoft technologies knowledge, such as xamarin, azure and dotnet, with other colleges.",
  },
  {
    year: 2018,
    description:
      "Founded Fedora UPS group where I improved my leading skills recluiting members and managing events. Also worked with Agrobiotechnology a biotech startup, creating their website and developing a couple of strategies.",
  },
  {
    year: 2019,
    description:
      "Started the IBM partnership journey, working with Project Managers and Infrastructure department. An amazing experience with a lot of learning about business process and IT assets alignment",
  },
  {
    year: 2020,
    description:
      "Founded Niovier, an startup that wanted to help small business to achieve success during pandemic",
  },
  {
    year: 2021,
    description:
      "Founded Conexperto with partners from many countries, where I used my development, leading, management and communication skills to develop a product for people experienced in any subject that wants to share it with someone",
  },
  {
    year: "2022",
    description:
      "Joined fiftyflowers, a US company in the flower market, as junior dev / tester where I started really soon to develop and run complex projects by my self and improved my english communication skills",
  },
  {
    year: "2023",
    description: "If you want me to join your journey on 2023 contact me! :)",
  },
];
---

<Layout>
  <div class="h-[80vh]" slot="main">
    <div class="flex flex-col justify-center h-full gap-10">
      <LottieAnimation src="../assets/rocker-launch.json" autoplay="visible" />
      <p class="font-anton text-9xl text-center text-white uppercase">
        martín larrea
      </p>
      <div>
        <p
          class="font-[Work Sans] font-bold tracking-[0.1em] text-3xl text-center text-white capitalize"
        >
          entrepreneur
        </p>
        <p
          class="font-[Work Sans] font-bold tracking-[0.1em] text-3xl text-center text-white capitalize"
        >
          software engineer
        </p>
      </div>
    </div>
  </div>
  <div slot="about-me">
    <div
      class="md:px-40 xl:px-80 flex flex-row md:flex-col justify-center items-center"
    >
      <Timeline milestones={milestones} />
    </div>
  </div>
  <div
    class="py-[300px] px-2 md:px-40 xl:px-80 flex flex-col gap-16 text-2xl font-[Work Sanss] text-white"
    slot="projects"
  >
    <Projects client:idle />
  </div>
</Layout>
